# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_SECURE_PROXY_SSL_HEADER=False

# Database
DATABASE_URL=postgres://condominio:condominio@db:5432/condominio

# Optional infrastructure reserved for future modules/background jobs.
REDIS_URL=redis://redis:6379/0

# Email
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@example.com

# Uploads/storage
DJANGO_STATIC_ROOT=staticfiles
DJANGO_MEDIA_ROOT=media
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
